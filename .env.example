# Google Cloud Project 1
DIALOGFLOW_PROJECT_ID_1="your-project-id-1"
DIALOGFLOW_AGENT_ID_1="your-agent-id-1"
DIALOGFLOW_LOCATION_1="us-central1"
DIALOGFLOW_LANGUAGE_1="fr"

# Optional: Base64-encoded service account key for Project 1.
# If omitted, Application Default Credentials (ADC) will be used.
# To use ADC locally: gcloud auth application-default login
GOOGLE_CLOUD_CREDENTIALS_BASE64_1=""

# Google Cloud Project 2 (failover)
